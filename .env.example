# Public site URL (canonical, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.finanshels.com

# --- Search engine verification (root metadata) ---
# Add the bare token (not the full meta tag). Found in:
#   Google: Search Console -> Settings -> Ownership verification -> HTML tag
#   Bing:   Bing Webmaster Tools -> Verify ownership -> Meta tag
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# --- Firebase Web SDK (client) ---
# Safe to expose in browser (public config), but still keep in env for portability.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firestore CMS (GCP) — optional; skip until you need live CMS ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
REVALIDATE_SECRET=

# --- CMS admin panel auth ---
# Bootstrap "owner" password used when no real users exist yet, or as a permanent
# break-glass login. Sign in at /admin/login with email empty + this password,
# then add real team members in /admin/settings/users.
CMS_ADMIN_PASSWORD=
# Optional lower-privilege bootstrap editor (legacy). Real users supersede this.
CMS_EDITOR_PASSWORD=
# REQUIRED in production. Long random string used to sign session cookies +
# verify password hashes. Generate with: openssl rand -hex 32
CMS_ADMIN_SESSION_SECRET=

# --- Chatbot widget ---
# Vercel AI Gateway key (preferred). When deployed on Vercel, the AI SDK can use
# the auto-injected OIDC token instead; set this only if you want explicit auth.
# Get one at https://vercel.com/dashboard → AI → API Keys.
AI_GATEWAY_API_KEY=
# Override the default chat model (gateway provider/model string).
# Default: anthropic/claude-haiku-4-5
CHAT_MODEL_ID=
# Optional fallback provider keys. The chat route tries AI_GATEWAY_API_KEY first,
# then falls back to these. If none are set, the widget returns 503.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Zoho CRM (Leads) — region .com ---
# Self-client OAuth (https://api-console.zoho.com). Scope:
#   ZohoCRM.modules.leads.CREATE,ZohoCRM.modules.leads.UPDATE
# 1) Create Self Client, generate grant token (10 min validity)
# 2) Exchange for refresh token via /oauth/v2/token (one-time)
# 3) Paste values below. Refresh token does not expire unless revoked.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# --- Outbound email (Resend) for CMS user invites + password resets ---
# Get a key at https://resend.com (free tier covers small teams).
# RESEND_FROM_EMAIL must use a domain you have verified in Resend.
# Format: either `email@example.com` or `Name <email@example.com>`.
# IMPORTANT: do NOT include surrounding quotes when pasting this into Vercel
# Environment Variables — paste the bare value, e.g.:
#     Finanshels CMS <no-reply@finanshels.com>
# (Local .env.* files do strip surrounding quotes; Vercel's UI does not.)
# When unset, invites still work but the system prints the invite URL to the
# admin UI / server logs instead of emailing it.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Finanshels CMS <no-reply@finanshels.com>
RESEND_REPLY_TO=

# --- Contact form ---
CONTACT_INBOX=

# --- Cloudflare Turnstile (bot protection on contact / lead forms) ---
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Misc ---
# Salt for hashing IPs in analytics events (any random string).
IP_HASH_SALT=
# Optional Firebase Storage bucket override (defaults to ${PROJECT_ID}.appspot.com).
FIREBASE_STORAGE_BUCKET=
