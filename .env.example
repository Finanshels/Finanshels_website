# Public site URL (canonical, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.finanshels.com

# --- Firebase Web SDK (client) ---
# Safe to expose in browser (public config), but still keep in env for portability.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firestore CMS (GCP) — optional; skip until you need live CMS ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
REVALIDATE_SECRET=

# --- CMS admin panel auth ---
# Bootstrap "owner" password used when no real users exist yet, or as a permanent
# break-glass login. Sign in at /admin/login with email empty + this password,
# then add real team members in /admin/settings/users.
CMS_ADMIN_PASSWORD=
# Optional lower-privilege bootstrap editor (legacy). Real users supersede this.
CMS_EDITOR_PASSWORD=
# REQUIRED in production. Long random string used to sign session cookies +
# verify password hashes. Generate with: openssl rand -hex 32
CMS_ADMIN_SESSION_SECRET=

# --- Outbound email (Resend) for CMS user invites + password resets ---
# Get a key at https://resend.com (free tier covers small teams).
# RESEND_FROM_EMAIL must use a domain you have verified in Resend.
# When unset, invites still work but the system prints the invite URL to the
# admin UI / server logs instead of emailing it.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Finanshels CMS <no-reply@finanshels.com>"
RESEND_REPLY_TO=
